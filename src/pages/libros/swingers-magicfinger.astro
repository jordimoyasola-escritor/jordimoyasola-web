<script>
  // ═══ AUDIO ENGINE ═══
  const audio = document.getElementById('main-audio');

  // Autoplay muteado
  audio.muted = true;
  audio.play().catch(() => {});

  let isPlaying = true;
  let isMuted = true;

  // Elementos flotante
  const btnPlay    = document.getElementById('btn-play');
  const iconPlay   = document.getElementById('icon-play');
  const iconPause  = document.getElementById('icon-pause');
  const btnMute    = document.getElementById('btn-mute');
  const iconMuted  = document.getElementById('icon-muted');
  const iconSound  = document.getElementById('icon-sound');
  const fill       = document.getElementById('progress-fill');
  const bar        = document.getElementById('progress-bar');

  // Elementos reproductor grande
  const btnPlayBig   = document.getElementById('btn-play-big');
  const iconPlayBig  = document.getElementById('icon-play-big');
  const iconPauseBig = document.getElementById('icon-pause-big');
  const btnMuteBig   = document.getElementById('btn-mute-big');
  const iconMutedBig = document.getElementById('icon-muted-big');
  const iconSoundBig = document.getElementById('icon-sound-big');
  const fillBig      = document.getElementById('progress-fill-big');
  const barBig       = document.getElementById('progress-bar-big');
  const timeCurrent  = document.getElementById('time-current');
  const timeTotal    = document.getElementById('time-total');

  function fmt(s) {
    const m = Math.floor(s / 60);
    const ss = Math.floor(s % 60).toString().padStart(2, '0');
    return `${m}:${ss}`;
  }

  function syncPlayIcons() {
    iconPlay.style.display   = isPlaying ? 'none' : 'block';
    iconPause.style.display  = isPlaying ? 'block' : 'none';
    iconPlayBig.style.display  = isPlaying ? 'none' : 'block';
    iconPauseBig.style.display = isPlaying ? 'block' : 'none';
  }

  function syncMuteIcons() {
    iconMuted.style.display    = isMuted ? 'block' : 'none';
    iconSound.style.display    = isMuted ? 'none' : 'block';
    iconMutedBig.style.display = isMuted ? 'block' : 'none';
    iconSoundBig.style.display = isMuted ? 'none' : 'block';
  }

  function togglePlay() {
    if (isPlaying) { audio.pause(); isPlaying = false; }
    else { audio.play(); isPlaying = true; }
    syncPlayIcons();
  }

  function toggleMute() {
    isMuted = !isMuted;
    audio.muted = isMuted;
    syncMuteIcons();
  }

  btnPlay.addEventListener('click', togglePlay);
  btnPlayBig.addEventListener('click', togglePlay);
  btnMute.addEventListener('click', toggleMute);
  btnMuteBig.addEventListener('click', toggleMute);

  // Progreso
  audio.addEventListener('timeupdate', () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    fill.style.width = pct + '%';
    fillBig.style.width = pct + '%';
    timeCurrent.textContent = fmt(audio.currentTime);
  });

  audio.addEventListener('loadedmetadata', () => {
    timeTotal.textContent = fmt(audio.duration);
  });

  // Click en barra de progreso
  function seek(e, el) {
    const rect = el.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  }
  bar.addEventListener('click', e => seek(e, bar));
  barBig.addEventListener('click', e => seek(e, barBig));

  // Visualizador animado (solo cuando suena y no está muteado)
  const bars = document.querySelectorAll('#visualizer .bar');
  let animFrame;
  function animateViz() {
    bars.forEach(b => {
      if (!audio.paused && !audio.muted) {
        b.style.height = (6 + Math.random() * 34) + 'px';
        b.style.opacity = (0.3 + Math.random() * 0.7).toString();
      }
    });
    animFrame = requestAnimationFrame(animateViz);
  }
  animateViz();

  // Formulario capítulo
  const SUPABASE_URL = 'https://yvbysknlztkcxrcnsczj.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2Ynlza25senRrY3hyY25zY3pqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3MzE2MzksImV4cCI6MjA4ODMwNzYzOX0._hqy4tFj-zkfqJapGfK9p_BH4EQvIMeBzYGtYlwhSVE';

  async function submitChapterForm(e) {
    e.preventDefault();
    const btn = document.getElementById('ch-submit');
    const msg = document.getElementById('ch-msg');
    btn.textContent = 'Procesando...'; btn.disabled = true;
    try {
      await fetch(SUPABASE_URL + '/rest/v1/chapter_requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ name: document.getElementById('ch-name').value, email: document.getElementById('ch-email').value, created_at: new Date().toISOString() })
      });
      const link = document.createElement('a');
      link.href = '/capitulo1-swingers-magicfinger.pdf';
      link.download = 'Capitulo1_Swingers_Magicfinger_JordiMoyaSola.pdf';
      link.click();
      msg.style.display = 'block';
      msg.textContent = '✓ Descarga iniciada. Bienvenido al Círculo Interior.';
      btn.textContent = '✓ Descargado';
    } catch(err) {
      msg.style.display = 'block'; msg.style.color = '#ff6b6b';
      msg.textContent = 'Error. Escríbenos a contacto@jordimoyasola.com';
      btn.textContent = 'Reintentar'; btn.disabled = false;
    }
  }
  window.submitChapterForm = submitChapterForm;
</script>
