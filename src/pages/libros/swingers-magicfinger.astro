---
/**
 * swingers-magicfinger.astro
 * URL: jordimoyasola.com/libros/swingers-magicfinger
 */
import Base   from '../../layouts/Base.astro';
import Nav    from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "Swingers: Magicfinger",
  "author": {
    "@type": "Person",
    "name": "Jordi Moya Solà",
    "url": "https://www.jordimoyasola.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Editorial Caligrama",
    "url": "https://www.caligramaeditorial.com"
  },
  "genre": ["Thriller psicológico", "Thriller erótico"],
  "inLanguage": "es",
  "url": "https://www.jordimoyasola.com/libros/swingers-magicfinger",
  "datePublished": "2026",
  "numberOfPages": 320,
  "bookFormat": "https://schema.org/Paperback",
  "description": "Tras una infidelidad, Leo y Clara intentan salvar su matrimonio adentrándose en el mundo oculto del intercambio de parejas. Una espiral de secretos, obsesión y manipulación.",
  "workExample": { "@type": "Book", "bookFormat": "https://schema.org/EBook", "inLanguage": "es" }
};
---

<Base
  title="Swingers: Magicfinger — Jordi Moya Solà · Thriller Psicológico"
  description="Tras una infidelidad que resquebraja los cimientos de su vida, Leo y Clara se adentran en el mundo oculto del intercambio de parejas. Una espiral de secretos y obsesión. Descarga gratis el primer capítulo."
  ogImage="/og-swingers.jpg"
  canonical="https://www.jordimoyasola.com/libros/swingers-magicfinger"
  schema={schema}
>
  <Nav slot="nav" currentPath="/libros" />

  <!-- Breadcrumb -->
  <div style="padding:140px 80px 0;max-width:var(--max-w);margin:0 auto;">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/libros">Libros</a>
      <span>›</span>
      <span style="color:var(--white-dim);">Swingers: Magicfinger</span>
    </nav>
  </div>

  <!-- ═══ HERO DEL LIBRO ═══ -->
  <section style="
    padding:0 80px 100px;
    background:var(--carbon);
    border-bottom:1px solid var(--border);
    display:grid;grid-template-columns:1fr 1.1fr;gap:100px;
    align-items:start;
    max-width:calc(var(--max-w) + 160px);margin:0 auto;
  ">
    <!-- Portada + estado -->
    <div class="rv" style="position:sticky;top:120px;">
      <div style="
        width:100%;aspect-ratio:2/3;
        background:linear-gradient(155deg,#1c1308 0%,#0c0a08 60%,#080808 100%);
        border:1px solid rgba(184,150,90,.25);
        display:flex;flex-direction:column;align-items:center;justify-content:center;
        padding:40px 32px;
        box-shadow:-20px 20px 80px rgba(0,0,0,.9),0 0 120px rgba(184,150,90,.06);
        position:relative;max-width:320px;
      ">
        <div style="position:absolute;top:16px;right:16px;background:var(--gold);color:var(--black);font-family:var(--sans);font-size:9px;font-weight:700;letter-spacing:.18em;padding:6px 12px;">PRÓXIMAMENTE</div>
        <div style="width:60%;height:1px;background:var(--gold);margin-bottom:24px;opacity:.7;"></div>
        <div style="
          font-family:var(--serif);font-size:22px;font-weight:900;
          color:var(--white);text-align:center;line-height:1.15;margin-bottom:16px;
        ">Swingers<br>Magicfinger</div>
        <div style="font-family:var(--sans);font-size:10px;letter-spacing:.2em;color:var(--gold);margin-bottom:24px;">Thriller Erótico Psicológico</div>
        <div style="width:24px;height:24px;border:1px solid rgba(184,150,90,.4);transform:rotate(45deg);margin-bottom:24px;"></div>
        <div style="font-family:var(--serif);font-size:12px;font-style:italic;color:var(--gold-dim);">Jordi Moya Solà</div>
        <div style="width:60%;height:1px;background:var(--gold);margin-top:24px;opacity:.4;"></div>
        <!-- Sello editorial -->
        <a href="https://www.caligramaeditorial.com" target="_blank" rel="noopener" style="
          position:absolute;bottom:0;left:0;right:0;
          background:rgba(212,175,55,.08);border-top:1px solid rgba(212,175,55,.2);
          padding:10px;display:flex;align-items:center;justify-content:center;gap:8px;
          text-decoration:none;transition:background .3s;
        " onmouseover="this.style.background='rgba(212,175,55,.15)'" onmouseout="this.style.background='rgba(212,175,55,.08)'">
          <span style="font-family:var(--sans);font-size:7px;letter-spacing:.3em;color:var(--gold-dim);text-transform:uppercase;">Publicado con</span>
          <span style="font-family:var(--serif);font-size:11px;font-style:italic;color:var(--gold);">Editorial Caligrama</span>
        </a>
      </div>

      <!-- Barra de progreso -->
      <div style="margin-top:24px;background:rgba(212,175,55,.06);border:1px solid rgba(212,175,55,.28);padding:24px 28px;">
        <div style="font-family:var(--sans);font-size:8.5px;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;margin-bottom:14px;">Publicación inminente · 2026</div>
        <div style="font-family:var(--sans);font-size:8px;letter-spacing:.3em;color:var(--menu-gray);text-transform:uppercase;margin-bottom:8px;">Progreso del manuscrito</div>
        <div style="height:3px;background:rgba(255,255,255,.06);overflow:hidden;">
          <div style="height:100%;width:95%;background:linear-gradient(to right,var(--gold-dim),var(--gold));"></div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:7px;">
          <span style="font-family:var(--sans);font-size:8px;color:rgba(212,175,55,.55);">Borrador</span>
          <span style="font-family:var(--sans);font-size:8px;color:var(--gold);font-weight:700;">95% completado</span>
          <span style="font-family:var(--sans);font-size:8px;color:rgba(212,175,55,.55);">Publicación</span>
        </div>
        <div style="margin-top:16px;font-family:var(--sans);font-size:13px;color:var(--white-dim);line-height:1.6;">
          Sé el primero en leerlo. <a href="/circulo-interior" style="color:var(--gold);text-decoration:none;border-bottom:1px solid rgba(212,175,55,.3);">Únete al Círculo Interior →</a>
        </div>
      </div>

      <a href="https://www.goodreads.com/author/show/jordimoyasola" target="_blank" rel="noopener" style="
        display:block;margin-top:16px;padding:14px;text-align:center;
        border:1px solid var(--border);
        font-family:var(--sans);font-size:11px;letter-spacing:.15em;color:var(--gold);
        text-decoration:none;text-transform:uppercase;transition:all .3s;
      " onmouseover="this.style.background='var(--gold-glow)'" onmouseout="this.style.background='transparent'">
        Añadir a Goodreads
      </a>
    </div>

    <!-- Contenido -->
    <div class="rv d1">
      <div class="s-label">La Obra</div>
      <h1 class="s-title">Swingers:<br><em>Magicfinger</em></h1>

      <!-- Hooks -->
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:32px;">
        {[
          '«¿Puede el deseo salvar un matrimonio… o destruirlo definitivamente?»',
          '«Una red clandestina donde nada es lo que parece. Y nadie está a salvo.»',
        ].map(h => (
          <div style="
            font-family:var(--serif);font-size:17px;font-style:italic;
            color:var(--white);padding:16px 20px;
            border-left:2px solid var(--gold);
            background:rgba(212,175,55,.04);
          ">{h}</div>
        ))}
      </div>

      <p style="font-family:var(--sans);font-size:16px;color:var(--white-dim);line-height:1.9;margin-bottom:20px;">
        Tras una infidelidad que resquebraja los cimientos de su vida, Leo y Clara intentan salvar su matrimonio adentrándose en el mundo oculto del intercambio de parejas. Lo que empieza como una búsqueda desesperada de libertad y perdón se transforma en algo mucho más oscuro.
      </p>
      <p style="font-family:var(--sans);font-size:16px;color:var(--white-dim);line-height:1.9;margin-bottom:32px;">
        Una espiral de secretos, obsesión y manipulación dentro de una red clandestina donde nada es lo que parece. Un viaje por el deseo, la culpa y el poder, narrado con una voz íntima y atmosférica que combina sensualidad, peligro y tensión emocional.
      </p>

      <!-- Pregunta de cierre -->
      <div style="
        font-family:var(--serif);font-size:22px;font-style:italic;
        color:var(--white);border:1px solid var(--border-strong);
        padding:28px 32px;margin-bottom:32px;text-align:center;
        background:rgba(212,175,55,.03);
      ">
        «¿Hasta dónde estás dispuesto a llegar para no perder lo que más amas?»
      </div>

      <!-- Badges -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:32px;">
        {['113.876 palabras','Thriller Psicológico','Editorial Caligrama','2026'].map(b => (
          <span style="
            font-family:var(--sans);font-size:12px;padding:6px 16px;
            border:1px solid var(--border);color:var(--menu-gray);
          ">{b}</span>
        ))}
      </div>

      <!-- CTAs -->
      <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:48px;">
        <a href="#extracto" class="btn-primary">Leer el primer capítulo gratis</a>
        <a href="/circulo-interior" class="btn-outline">Acceso anticipado</a>
      </div>

      <!-- ─── TESTIMONIOS LECTORES BETA ─── -->
      <div style="display:flex;flex-direction:column;gap:2px;margin-top:8px;">
        <div style="
          display:flex;align-items:center;gap:20px;
          margin-bottom:4px;padding-bottom:20px;
          border-bottom:1px solid var(--border);
        ">
          <div style="width:6px;height:6px;background:var(--gold);transform:rotate(45deg);"></div>
          <div>
            <div style="font-family:var(--sans);font-size:8px;letter-spacing:.45em;color:var(--gold);text-transform:uppercase;">Lectura Beta · Manuscrito</div>
            <div style="font-family:var(--sans);font-size:13px;color:var(--white-dim);margin-top:3px;font-style:italic;">Primeras impresiones sobre el manuscrito previo a publicación</div>
          </div>
        </div>

        {[
          { text: '«Una primera novela que te atrapa desde la primera página y no te suelta hasta el final. La voz de Jordi Moya Solà es íntima, perturbadora y absolutamente hipnótica.»', author: 'María G. · Barcelona', role: 'LECTOR/A BETA' },
          { text: '«Hacía tiempo que no leía algo que me removiera tanto por dentro. Los personajes tienen una complejidad psicológica que no esperaba. El ritmo es perfecto.»', author: 'Carles M. · Club de Lectura, Granollers', role: 'CLUB DE LECTURA' },
          { text: '«Swingers: Magicfinger es la clase de libro que te obliga a mirarte a ti mismo con incomodidad. Valiente, oscuro y necesario.»', author: 'Anna R. · @annaleesbookscat', role: 'BOOKSTAGRAM' },
        ].map(r => (
          <div style="padding:28px;background:var(--charcoal);border:1px solid var(--border);position:relative;">
            <div style="
              position:absolute;top:20px;right:20px;
              font-family:var(--sans);font-size:7px;letter-spacing:.3em;
              color:var(--gold-dim);text-transform:uppercase;
              border:1px solid var(--border);padding:3px 8px;
            ">{r.role}</div>
            <p style="font-family:var(--serif);font-size:18px;font-style:italic;color:var(--white);line-height:1.5;margin-bottom:16px;">{r.text}</p>
            <div style="font-family:var(--sans);font-size:8.5px;letter-spacing:.4em;color:var(--gold-dim);text-transform:uppercase;">— {r.author}</div>
          </div>
        ))}

        <div style="padding:16px 20px;background:rgba(212,175,55,.03);border:1px solid var(--border);display:flex;align-items:flex-start;gap:14px;">
          <span style="color:var(--gold);font-size:14px;flex-shrink:0;">◆</span>
          <p style="font-family:var(--sans);font-size:11px;letter-spacing:.05em;color:var(--gold-dim);line-height:1.7;font-style:italic;">
            Testimonios recogidos durante la lectura beta del manuscrito completo. Publicación prevista en 2026 con Editorial Caligrama.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EXTRACTO — CAPÍTULO 1 ═══ -->
  <section id="extracto" style="
    padding:var(--section-pad);background:var(--black);
    border-top:1px solid var(--border);
  ">
    <div style="max-width:700px;margin:0 auto;">
      <div class="rv" style="text-align:center;margin-bottom:64px;">
        <div class="s-label" style="justify-content:center;">Capítulo 1</div>
        <h2 class="s-title" style="text-align:center;">Setecientas <em>noches</em></h2>
        <p style="font-family:var(--sans);font-size:12px;letter-spacing:.2em;color:var(--menu-gray);text-align:center;margin-top:8px;">Swingers: Magicfinger · Jordi Moya Solà</p>
      </div>

      <p class="rv" style="font-family:var(--sans);font-size:17px;line-height:2;color:var(--white);border-left:1px solid rgba(212,175,55,.42);padding-left:40px;margin-bottom:24px;">
        La contraseña era el cumpleaños de Álex. Leo lo supo antes de teclearla. Lo supo mientras sus dedos temblaban sobre el teclado del portátil de Clara, suspendidos en el aire como pájaros que presienten la tormenta. El reloj de la cocina marcaba las once y media con su tic-tac insistente, cada segundo era una gota de tiempo cayendo sobre su pecho, y ella seguía sin volver del «supermercado».
      </p>
      <p class="rv d1" style="font-family:var(--sans);font-size:17px;line-height:2;color:var(--white-dim);border-left:1px solid rgba(212,175,55,.18);padding-left:40px;margin-bottom:24px;">
        La sospecha no irrumpe en la vida como un rayo que parte el cielo en dos. Es más bien una llovizna persistente, fina y silenciosa, que se filtra por los huecos del alma hasta empaparla por completo.
      </p>
      <p class="rv d2" style="font-family:var(--sans);font-size:17px;line-height:2;color:var(--white-dim);border-left:1px solid rgba(212,175,55,.18);padding-left:40px;">
        Leo tecleó los números. 0-3-1-0-2-0-0-6. El cumpleaños de su hijo se convirtió en la llave que abriría la puerta a su propia destrucción. La pantalla se desbloqueó con un destello azul.
      </p>

      <!-- Fade -->
      <div style="height:120px;background:linear-gradient(transparent,var(--black));margin-top:-60px;position:relative;z-index:2;"></div>

      <!-- CTA capítulo completo -->
      <div class="rv" style="text-align:center;padding-top:48px;position:relative;z-index:3;">
        <p style="font-family:var(--serif);font-size:20px;font-style:italic;color:var(--white);margin-bottom:8px;">Faltan tres páginas. Las más duras.</p>
        <p style="font-family:var(--sans);font-size:13px;letter-spacing:.08em;color:var(--menu-gray);margin-bottom:28px;">El capítulo completo es gratis. Solo necesitas un email.</p>
        <button onclick="document.getElementById('modal-chapter').style.display='flex'" class="btn-primary">Leer el capítulo completo — gratis</button>
      </div>
    </div>
  </section>

  <!-- Modal captura email -->
  <div id="modal-chapter" data-modal style="
    display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);
    z-index:99000;align-items:center;justify-content:center;padding:20px;
  " onclick="if(event.target===this)this.style.display='none'">
    <div style="background:var(--charcoal);border:1px solid var(--border-strong);max-width:480px;width:100%;padding:52px 44px;position:relative;">
      <button onclick="document.getElementById('modal-chapter').style.display='none'" style="position:absolute;top:16px;right:20px;background:none;border:none;color:var(--menu-gray);font-size:20px;cursor:pointer;">✕</button>
      <span style="font-family:var(--sans);font-size:11px;letter-spacing:.3em;color:var(--gold);display:block;margin-bottom:16px;">ACCESO GRATUITO</span>
      <div style="font-family:var(--serif);font-size:24px;font-style:italic;color:var(--white);margin-bottom:8px;">Capítulo 1 completo</div>
      <p style="font-family:var(--sans);font-size:14px;color:var(--menu-gray);margin-bottom:32px;line-height:1.7;">Descarga el primer capítulo completo de <em>Swingers: Magicfinger</em> en PDF. Gratis.</p>
      <form id="form-chapter" onsubmit="submitChapterForm(event)">
        <div class="form-field"><input type="text" id="ch-name" placeholder="Nombre *" required></div>
        <div class="form-field"><input type="email" id="ch-email" placeholder="Correo electrónico *" required></div>
        <div class="form-field" style="display:flex;align-items:flex-start;gap:10px;padding:4px 0 16px;">
          <input type="checkbox" id="ch-gdpr" required style="width:auto;margin-top:4px;accent-color:#D4AF37;">
          <label for="ch-gdpr" style="font-family:var(--sans);font-size:11px;color:var(--menu-gray);line-height:1.6;cursor:pointer;">
            Acepto recibir el capítulo y comunicaciones. <a href="/privacidad" style="color:var(--gold);">Privacidad</a> (RGPD)
          </label>
        </div>
        <button type="submit" class="form-submit" id="ch-submit">Descargar el capítulo completo</button>
        <div id="ch-msg" style="display:none;margin-top:16px;font-family:var(--sans);font-size:13px;color:var(--gold);text-align:center;"></div>
      </form>
      <div style="margin-top:20px;font-family:var(--sans);font-size:10px;letter-spacing:.15em;color:var(--gold-dim);text-align:center;">🔒 Datos protegidos · RGPD · No spam</div>
    </div>
  </div>

  <Footer slot="footer" />
</Base>

<script>
  const SUPABASE_URL = 'https://yvbysknlztkcxrcnsczj.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2Ynlza25senRrY3hyY25zY3pqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3MzE2MzksImV4cCI6MjA4ODMwNzYzOX0._hqy4tFj-zkfqJapGfK9p_BH4EQvIMeBzYGtYlwhSVE';

  async function submitChapterForm(e) {
    e.preventDefault();
    const btn = document.getElementById('ch-submit');
    const msg = document.getElementById('ch-msg');
    btn.textContent = 'Procesando...'; btn.disabled = true;
    try {
      if (SUPABASE_URL && SUPABASE_KEY) {
        await fetch(SUPABASE_URL + '/rest/v1/chapter_requests', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Prefer': 'return=minimal' },
          body: JSON.stringify({ name: document.getElementById('ch-name').value, email: document.getElementById('ch-email').value, created_at: new Date().toISOString() })
        });
      }
      const link = document.createElement('a');
      link.href = '/capitulo1-swingers-magicfinger.pdf';
      link.download = 'Capitulo1_Swingers_Magicfinger_JordiMoyaSola.pdf';
      link.click();
      msg.style.display = 'block';
      msg.textContent = '✓ Descarga iniciada. Bienvenido al Círculo Interior.';
      btn.textContent = '✓ Descargado';
    } catch(err) {
      msg.style.display = 'block'; msg.style.color = '#ff6b6b';
      msg.textContent = 'Error. Escríbenos a contacto@jordimoyasola.com';
      btn.textContent = 'Reintentar'; btn.disabled = false;
    }
  }
  window.submitChapterForm = submitChapterForm;
</script>
