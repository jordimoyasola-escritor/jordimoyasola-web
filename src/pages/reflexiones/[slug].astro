---
/**
 * [slug].astro — Plantilla dinámica para artículos del blog
 * URL: jordimoyasola.com/reflexiones/[slug]
 *
 * Astro lee los .md de src/content/reflexiones/
 * y genera una página por cada uno automáticamente.
 */
import { getCollection, getEntry } from 'astro:content';
import Base   from '../../layouts/Base.astro';
import Nav    from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('reflexiones');
  return articles.map(a => ({
    params: { slug: a.slug },
    props:  { article: a },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const { title, description, date, tag, readTime } = article.data;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": {
    "@type": "Person",
    "name": "Jordi Moya Solà",
    "url": "https://www.jordimoyasola.com"
  },
  "publisher": {
    "@type": "Person",
    "name": "Jordi Moya Solà",
    "url": "https://www.jordimoyasola.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.jordimoyasola.com/reflexiones/${article.slug}`
  }
};
---

<Base
  title={`${title} — Jordi Moya Solà`}
  description={description}
  canonical={`https://www.jordimoyasola.com/reflexiones/${article.slug}`}
  schema={schema}
>
  <Nav slot="nav" currentPath="/reflexiones" />

  <article style="max-width:800px;margin:0 auto;padding:140px 40px 100px;">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/reflexiones">Reflexiones</a>
      <span>›</span>
      <span style="color:var(--white-dim);">{title}</span>
    </nav>

    <!-- Meta -->
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:40px;">
      <span style="font-family:var(--sans);font-size:7px;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;background:rgba(212,175,55,.08);border:1px solid var(--border);padding:5px 12px;">{tag}</span>
      <span style="font-family:var(--sans);font-size:12px;letter-spacing:.15em;color:var(--menu-gray);">{date}</span>
      {readTime && <span style="font-family:var(--sans);font-size:12px;color:var(--menu-gray);">{readTime} min de lectura</span>}
    </div>

    <!-- Título -->
    <h1 class="s-title" style="font-size:clamp(32px,4vw,52px);margin-bottom:16px;" set:html={title.replace(/\*(.*?)\*/g, '<em>$1</em>')} />
    <div class="gold-bar"></div>

    <!-- Bajada -->
    {description && (
      <p style="font-family:var(--serif);font-size:20px;font-style:italic;color:var(--white-dim);line-height:1.7;margin-bottom:56px;">{description}</p>
    )}

    <!-- Contenido del artículo (Markdown) -->
    <div class="article-body">
      <Content />
    </div>

    <!-- Firma del autor -->
    <div style="margin-top:64px;padding-top:40px;border-top:1px solid var(--border);display:flex;align-items:center;gap:24px;">
      <div style="width:56px;height:56px;background:var(--charcoal);border:1px solid var(--border-strong);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span style="font-family:var(--serif);font-size:22px;font-style:italic;color:var(--gold);">J</span>
      </div>
      <div>
        <div style="font-family:var(--serif);font-size:18px;font-weight:700;color:var(--white);margin-bottom:4px;">Jordi Moya Solà</div>
        <div style="font-family:var(--sans);font-size:13px;color:var(--menu-gray);">Escritor de thriller psicológico · L'Ametlla del Vallès, Barcelona</div>
      </div>
    </div>

    <!-- CTA siguiente paso -->
    <div style="margin-top:56px;padding:40px;background:var(--charcoal);border:1px solid var(--border-strong);text-align:center;">
      <div style="font-family:var(--sans);font-size:9px;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;margin-bottom:16px;">¿Te ha interesado este artículo?</div>
      <p style="font-family:var(--serif);font-size:20px;font-style:italic;color:var(--white);margin-bottom:24px;">Únete al Círculo Interior — el proceso real, sin filtros.</p>
      <a href="/circulo-interior" class="btn-primary">Acceso gratuito</a>
    </div>
  </article>

  <Footer slot="footer" />
</Base>

<style is:global>
  /* Estilos para el cuerpo del artículo generado por Markdown */
  .article-body {
    font-family: var(--sans);
    font-size: 17px;
    line-height: 2;
    color: var(--white-dim);
  }
  .article-body p { margin-bottom: 28px; }
  .article-body h2 {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
    margin: 56px 0 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .article-body h3 {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--white);
    margin: 40px 0 16px;
  }
  .article-body blockquote {
    font-family: var(--serif);
    font-size: 20px;
    font-style: italic;
    color: var(--white);
    border-left: 2px solid var(--gold);
    padding: 20px 28px;
    margin: 40px 0;
    background: rgba(212,175,55,.04);
  }
  .article-body strong { color: var(--white); font-weight: 700; }
  .article-body em { font-style: italic; }
  .article-body a { color: var(--gold); text-decoration: none; border-bottom: 1px solid rgba(212,175,55,.3); transition: border-color .3s; }
  .article-body a:hover { border-color: var(--gold); }
  .article-body ul { list-style: none; margin: 28px 0; padding: 0; }
  .article-body ul li {
    padding: 12px 0 12px 28px;
    border-bottom: 1px solid var(--white-faint);
    position: relative;
  }
  .article-body ul li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 7px;
    top: 16px;
  }
</style>
