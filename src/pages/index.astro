<script>
  // Modal capítulo — formulario home
  const SUPA_URL = 'https://yvbysknlztkcxrcnsczj.supabase.co';
  const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl2Ynlza25senRrY3hyY25zY3pqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3MzE2MzksImV4cCI6MjA4ODMwNzYzOX0._hqy4tFj-zkfqJapGfK9p_BH4EQvIMeBzYGtYlwhSVE';

  async function submitChapterHome(e) {
    e.preventDefault();
    const btn   = document.getElementById('ch-submit-h');
    const msg   = document.getElementById('ch-msg-h');
    const name  = document.getElementById('ch-name-h').value;
    const email = document.getElementById('ch-email-h').value;
    btn.textContent = 'Procesando...'; btn.disabled = true;
    try {
      await fetch(SUPA_URL + '/rest/v1/chapter_requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPA_KEY, 'Authorization': 'Bearer ' + SUPA_KEY, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ name, email, book: 'swingers-magicfinger', created_at: new Date().toISOString() })
      });
      const link = document.createElement('a');
      link.href = '/capitulo1-swingers-magicfinger.pdf';
      link.download = 'Capitulo1_Swingers_Magicfinger_JordiMoyaSola.pdf';
      link.click();
      msg.style.display = 'block';
      msg.textContent = '\u2713 Descarga iniciada. Bienvenido al C\xedrculo Interior.';
      btn.textContent = '\u2713 Descargado';
      setTimeout(() => { document.getElementById('modal-chapter').style.display='none'; document.body.style.overflow=''; }, 2500);
    } catch(err) {
      msg.style.display='block'; msg.style.color='#ff6b6b';
      msg.textContent='Error al procesar. Escr\xedbenos a hola@jordimoyasola.com';
      btn.textContent='Reintentar'; btn.disabled=false;
    }
  }
  window.submitChapterHome = submitChapterHome;

  // Typewriter hero
  const el = document.getElementById('typewriter-text');
  if (el) {
    const text = 'La voz que perturbará tu forma de leer thriller';
    let i = 0;
    setTimeout(() => {
      const interval = setInterval(() => {
        el.textContent += text[i]; i++;
        if (i >= text.length) clearInterval(interval);
      }, 42);
    }, 1200);
  }

  // Parallax libro en hero
  const bookWrap = document.getElementById('book-wrap');
  const hero = document.getElementById('hero');
  if (hero && bookWrap) {
    hero.addEventListener('mousemove', e => {
      const rect = hero.getBoundingClientRect();
      const cx = (e.clientX - rect.left) / rect.width  - 0.5;
      const cy = (e.clientY - rect.top)  / rect.height - 0.5;
      bookWrap.style.transform = `translate(-50%,-50%) perspective(900px) rotateY(${cx*-6}deg) rotateX(${cy*4}deg)`;
    });
    hero.addEventListener('mouseleave', () => {
      bookWrap.style.transform = 'translate(-50%,-50%)';
    });
  }
</script>
