---
/**
 * index.astro — Página de inicio
 * jordimoyasola.com/
 */
import Base from '../layouts/Base.astro';
import Nav  from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Jordi Moya Solà",
    "url": "https://www.jordimoyasola.com",
    "sameAs": [
      "https://www.instagram.com/jordimoyasola",
      "https://www.tiktok.com/@jordimoyasola",
      "https://www.goodreads.com/author/show/jordimoyasola"
    ],
    "jobTitle": "Escritor",
    "description": "Escritor español de thriller psicológico. Autor de Swingers: Magicfinger, Locked In y Combustión.",
    "birthPlace": { "@type": "Place", "name": "Granollers, Barcelona" }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Jordi Moya Solà — Thriller Psicológico",
    "url": "https://www.jordimoyasola.com",
    "potentialAction": {
      "@type": "ReadAction",
      "target": "https://www.jordimoyasola.com/libros/swingers-magicfinger#extracto"
    }
  }
];
---

<Base
  title="Jordi Moya Solà — Thriller Psicológico"
  description="Escritor de thriller psicológico. Autor de Swingers: Magicfinger, Locked In y Combustión. Descarga gratis el primer capítulo."
  schema={schema}
>
  <Nav slot="nav" currentPath="/" />

  <!-- ═══ HERO ═══ -->
  <section id="hero" style="
    min-height:100vh;
    display:grid;
    grid-template-columns:52% 48%;
    position:relative;
    overflow:hidden;
  ">
    <div style="
      display:flex; flex-direction:column; justify-content:center;
      padding:148px 72px 100px 80px;
      position:relative; z-index:2;
    ">
      <div style="
        font-family:var(--sans); font-size:13px; letter-spacing:.25em; color:var(--gold);
        text-transform:uppercase; margin-bottom:44px;
        display:flex; align-items:center; gap:20px;
        opacity:0; animation:fu .9s .2s forwards; font-weight:700;
      ">
        <span style="width:32px;height:1px;background:var(--gold);display:inline-block;"></span>
        Swingers: Magicfinger · Thriller Psicológico · Segundo semestre 2026
      </div>

      <h1 style="
        font-family:var(--serif); font-size:clamp(48px,6vw,90px); font-weight:900;
        line-height:.95; color:var(--white); margin-bottom:20px;
        opacity:0; animation:fu .9s .4s forwards;
      ">
        Jordi Moya<br>
        <em style="font-style:normal;color:var(--gold);">Solà</em>
      </h1>

      <p style="
        font-family:var(--sans); font-size:14px; letter-spacing:.15em; color:var(--menu-gray);
        margin-bottom:48px; opacity:0; animation:fu .9s .6s forwards; font-weight:300;
      ">
        <span id="typewriter-text"></span>
        <span id="typewriter-cursor" style="
          display:inline-block;width:2px;height:1em;background:var(--gold);
          margin-left:2px;vertical-align:middle;animation:twblink .8s step-end infinite;
        "></span>
      </p>

      <blockquote style="
        font-family:var(--sans); font-size:17px; font-style:italic; color:var(--white-dim);
        line-height:1.8; max-width:440px;
        border-left:1px solid rgba(212,175,55,.42); padding-left:28px; margin-bottom:60px;
        opacity:0; animation:fu .9s .8s forwards;
      ">
        «Hay verdades que solo emergen en la oscuridad. Personajes cuya lógica interna te resulta perturbadoramente comprensible.»
      </blockquote>

      <div style="display:flex;gap:28px;align-items:center;opacity:0;animation:fu .9s 1s forwards;">
        <a href="/libros/swingers-magicfinger#extracto" class="btn-primary">Leer el primer capítulo gratis</a>
        <a href="/libros" class="btn-ghost">Ver todos los libros</a>
      </div>
    </div>

    <!-- Lado derecho — portada libro CSS -->
    <div style="position:relative;overflow:hidden;background:linear-gradient(160deg,#0f0c08,#080808);">
      <div style="
        position:absolute;inset:0;
        background:
          radial-gradient(ellipse at 35% 45%,rgba(184,150,90,.07) 0%,transparent 55%),
          radial-gradient(ellipse at 80% 80%,rgba(184,150,90,.03) 0%,transparent 40%);
      "></div>

      <!-- Libro 3D CSS -->
      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);" id="book-wrap">
        <div style="
          width:200px;height:280px;
          background:linear-gradient(155deg,#1c1308 0%,#0c0a08 60%,#080808 100%);
          border:1px solid rgba(184,150,90,.25);
          display:flex;flex-direction:column;align-items:center;justify-content:center;
          padding:28px 20px;
          box-shadow:-20px 20px 60px rgba(0,0,0,.9),0 0 80px rgba(184,150,90,.06);
          position:relative;
        ">
          <div style="width:100%;height:1px;background:var(--gold);margin-bottom:20px;opacity:.7;"></div>
          <div style="
            font-family:var(--serif);font-size:20px;font-weight:900;
            color:var(--white);text-align:center;line-height:1.1;margin-bottom:20px;
          ">Swingers<br>Magicfinger</div>
          <div style="
            width:24px;height:24px;border:1px solid rgba(184,150,90,.4);
            transform:rotate(45deg);margin-bottom:20px;
          "></div>
          <div style="font-family:var(--serif);font-size:10px;color:var(--gold-dim);letter-spacing:.1em;">Jordi Moya Solà</div>
          <div style="width:100%;height:1px;background:var(--gold);margin-top:20px;opacity:.4;"></div>
        </div>
        <div style="
          position:absolute;bottom:-16px;left:16px;right:-16px;height:16px;
          background:linear-gradient(to right,rgba(0,0,0,.8),rgba(0,0,0,.3));
          filter:blur(8px);
        "></div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <div style="
    display:grid;grid-template-columns:repeat(4,1fr);
    border-top:1px solid var(--border);
  ">
    {[
      { n: '13', l: 'Años construyendo este universo' },
      { n: '3',  l: 'Novelas en desarrollo' },
      { n: '2',  l: 'Idiomas · ES · CA' },
      { n: '1',  l: 'Universo narrativo en expansión' },
    ].map((s, i) => (
      <div class={`rv${i>0?' d'+i:''}`} style="
        padding:48px 40px;
        border-right:1px solid var(--border);
        text-align:center;
      ">
        <div style="
          font-family:var(--serif);font-size:clamp(40px,5vw,72px);
          font-weight:900;color:var(--gold);line-height:1;margin-bottom:12px;
        ">{s.n}</div>
        <div style="
          font-family:var(--sans);font-size:12px;letter-spacing:.1em;
          color:var(--menu-gray);text-transform:uppercase;
        ">{s.l}</div>
      </div>
    ))}
  </div>

  <!-- ═══ LIBROS PREVIEW ═══ -->
  <section style="padding:var(--section-pad);background:var(--black);border-top:1px solid var(--border);">
    <div style="max-width:var(--max-w);margin:0 auto;">
      <div class="rv" style="text-align:center;margin-bottom:80px;">
        <div class="s-label" style="justify-content:center;">La Obra</div>
        <h2 class="s-title" style="text-align:center;">El universo <em>Moya Solà</em></h2>
        <p style="font-family:var(--sans);font-size:14px;color:var(--menu-gray);max-width:520px;margin:16px auto 0;line-height:1.8;">
          Tres novelas. Dos mundos conectados. Un territorio psicológico que no suelta al lector.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;">
        {[
          {
            href: '/libros/swingers-magicfinger',
            num: 'I', status: 'En breve', pct: '95%',
            title: 'Swingers:\nMagicfinger',
            genre: 'Thriller Psicológico',
            desc: 'El deseo como arma. La infidelidad como puerta a lo irrecuperable.',
          },
          {
            href: '/libros/locked-in',
            num: 'II', status: 'En producción', pct: '81%',
            title: 'Locked In',
            genre: 'Thriller Psicológico',
            desc: 'Consciente pero inmóvil. Damián lo oye todo. No puede comunicar nada.',
          },
          {
            href: '/libros/combustion',
            num: 'III', status: 'Próximamente', pct: '',
            title: 'Combustión',
            genre: 'Thriller Policial · Bilogía I',
            desc: 'Inspector Alavedra. Barcelona, 2010. Crímenes que no deberían existir.',
            badge: 'PRÓXIMAMENTE',
          },
        ].map((b, i) => (
          <a href={b.href} class={`rv${i>0?' d'+i:''}`} style="
            display:block;background:var(--charcoal);
            border:1px solid var(--border);padding:48px 36px;
            text-decoration:none;color:inherit;
            transition:border-color .4s;position:relative;overflow:hidden;
          " onmouseover="this.style.borderColor='rgba(212,175,55,.6)'"
             onmouseout="this.style.borderColor='rgba(212,175,55,.18)'">
            {b.badge && (
              <div style="
                position:absolute;top:16px;right:16px;
                background:#CC0000;color:#fff;
                font-family:var(--sans);font-size:7px;font-weight:700;
                letter-spacing:.25em;padding:4px 10px;
              ">{b.badge}</div>
            )}
            <div style="
              display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;
            ">
              <div style="font-family:var(--sans);font-size:8px;letter-spacing:.5em;color:var(--gold);text-transform:uppercase;">{b.num} · {b.status}</div>
              {b.pct && <div style="font-family:var(--sans);font-size:8px;color:var(--gold);font-weight:700;">{b.pct}</div>}
            </div>
            <div style="font-family:var(--serif);font-size:22px;font-weight:900;color:var(--white);line-height:1.2;margin-bottom:10px;white-space:pre-line;">{b.title}</div>
            <div style="font-family:var(--sans);font-size:11px;color:var(--gold);letter-spacing:.2em;margin-bottom:16px;">{b.genre}</div>
            <p style="font-family:var(--sans);font-size:14px;color:var(--white-dim);line-height:1.7;margin-bottom:24px;">{b.desc}</p>
            <div style="font-family:var(--sans);font-size:11px;letter-spacing:.2em;color:var(--gold);display:flex;align-items:center;gap:8px;">Leer más →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ EXTRACTO — CAPÍTULO 1 ═══ -->
  <section id="extracto" style="
    padding:var(--section-pad);
    background:var(--carbon);
    border-top:1px solid var(--border);
  ">
    <div style="max-width:700px;margin:0 auto;">
      <div class="rv" style="text-align:center;margin-bottom:64px;">
        <div class="s-label" style="justify-content:center;">004 — Capítulo 1</div>
        <h2 class="s-title" style="text-align:center;">Setecientas <em>noches</em></h2>
        <p style="font-family:var(--sans);font-size:12px;letter-spacing:.2em;color:var(--menu-gray);text-align:center;margin-top:8px;">
          Swingers: Magicfinger · Jordi Moya Solà
        </p>
      </div>

      <!-- Párrafos del extracto con fade progresivo -->
      <p class="rv" style="
        font-family:var(--sans);font-size:17px;line-height:2;color:var(--white);
        border-left:2px solid rgba(212,175,55,.6);padding-left:40px;margin-bottom:28px;
      ">
        La contraseña era el cumpleaños de Álex. Leo lo supo antes de teclearla. Lo supo mientras
        sus dedos temblaban sobre el teclado del portátil de Clara, suspendidos en el aire como
        pájaros que presienten la tormenta. El reloj de la cocina marcaba las once y media con su
        tic-tac insistente, cada segundo era una gota de tiempo cayendo sobre su pecho, y ella
        seguía sin volver del «supermercado».
      </p>
      <p class="rv d1" style="
        font-family:var(--sans);font-size:17px;line-height:2;color:var(--white-dim);
        border-left:1px solid rgba(212,175,55,.25);padding-left:40px;margin-bottom:28px;
        font-style:italic;
      ">
        La sospecha no irrumpe en la vida como un rayo que parte el cielo en dos. Es más bien una
        llovizna persistente, fina y silenciosa, que se filtra por los huecos del alma hasta
        empaparla por completo.
      </p>
      <p class="rv d2" style="
        font-family:var(--sans);font-size:17px;line-height:2;color:var(--white-dim);
        border-left:1px solid rgba(212,175,55,.15);padding-left:40px;
      ">
        Leo tecleó los números. 0-3-1-0-2-0-0-6. El cumpleaños de su hijo —esa fecha que había
        celebrado con velas y risas apenas semanas atrás— se convirtió en la llave que abriría la
        puerta a su propia destrucción. La pantalla se desbloqueó con un destello azul.
      </p>

      <!-- Fade de desvanecimiento -->
      <div style="
        height:140px;
        background:linear-gradient(transparent, var(--carbon));
        margin-top:-80px;position:relative;z-index:2;
      "></div>

      <!-- CTA descarga -->
      <div class="rv" style="text-align:center;padding-top:40px;position:relative;z-index:3;">
        <p style="
          font-family:var(--serif);font-size:22px;font-style:italic;
          color:var(--white);margin-bottom:10px;
        ">Faltan tres páginas. Las más duras.</p>
        <p style="
          font-family:var(--sans);font-size:13px;letter-spacing:.08em;
          color:var(--menu-gray);margin-bottom:32px;
        ">El capítulo completo es gratis. Solo necesitas un email.</p>
        <button
          onclick="document.getElementById('modal-chapter').style.display='flex';document.body.style.overflow='hidden';"
          class="btn-primary"
          style="font-size:14px;padding:18px 48px;"
        >
          Leer el capítulo completo — gratis
        </button>
        <div style="margin-top:16px;">
          <a href="/libros/swingers-magicfinger" class="btn-ghost" style="font-size:12px;">
            Ver la página del libro
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MODAL — CAPÍTULO 1 ═══ -->
  <div
    id="modal-chapter"
    data-modal
    style="
      display:none;position:fixed;inset:0;
      background:rgba(0,0,0,.93);
      z-index:99000;
      align-items:center;justify-content:center;
      padding:20px;
    "
    onclick="if(event.target===this){this.style.display='none';document.body.style.overflow=''}"
  >
    <div style="
      background:var(--charcoal);
      border:1px solid var(--border-strong);
      max-width:480px;width:100%;
      padding:52px 44px;
      position:relative;
    ">
      <!-- Cerrar -->
      <button
        onclick="document.getElementById('modal-chapter').style.display='none';document.body.style.overflow='';"
        style="
          position:absolute;top:16px;right:20px;
          background:none;border:none;
          color:var(--menu-gray);font-size:22px;
          cursor:pointer;line-height:1;
          transition:color .3s;
        "
        onmouseover="this.style.color='var(--white)'"
        onmouseout="this.style.color='var(--menu-gray)'"
        aria-label="Cerrar"
      >✕</button>

      <span style="
        font-family:var(--sans);font-size:9px;letter-spacing:.4em;
        color:var(--gold);display:block;margin-bottom:20px;text-transform:uppercase;
      ">ACCESO GRATUITO</span>

      <div style="
        font-family:var(--serif);font-size:26px;font-style:italic;
        color:var(--white);margin-bottom:10px;line-height:1.2;
      ">Capítulo 1 completo</div>

      <p style="
        font-family:var(--sans);font-size:14px;color:var(--menu-gray);
        margin-bottom:32px;line-height:1.8;
      ">
        Descarga el primer capítulo completo de
        <em style="color:var(--white-dim);">Swingers: Magicfinger</em> en PDF.
        Gratis. Sin compromisos.
      </p>

      <form id="form-chapter-home" onsubmit="submitChapterHome(event)">
        <div class="form-field">
          <input type="text" id="ch-name-h" placeholder="Nombre *" required>
        </div>
        <div class="form-field">
          <input type="email" id="ch-email-h" placeholder="Correo electrónico *" required>
        </div>
        <div class="form-field" style="display:flex;align-items:flex-start;gap:12px;padding:6px 0 18px;">
          <input type="checkbox" id="ch-gdpr-h" required style="width:auto;margin-top:3px;accent-color:#D4AF37;flex-shrink:0;">
          <label for="ch-gdpr-h" style="
            font-family:var(--sans);font-size:12px;
            color:var(--menu-gray);line-height:1.6;cursor:pointer;
          ">
            Acepto recibir el capítulo y comunicaciones del autor.
            <a href="/privacidad" style="color:var(--gold);">Privacidad</a>. (RGPD)
          </label>
        </div>
        <button type="submit" class="form-submit" id="ch-submit-h">
          Descargar el capítulo completo
        </button>
        <div id="ch-msg-h" style="
          display:none;margin-top:16px;
          font-family:var(--sans);font-size:13px;
          color:var(--gold);text-align:center;
        "></div>
      </form>

      <div style="
        margin-top:24px;
        font-family:var(--sans);font-size:9px;
        letter-spacing:.2em;color:var(--gold-dim);
        text-align:center;text-transform:uppercase;
      ">🔒 RGPD · Sin spam · Baja en cualquier momento</div>
    </div>
  </div>

  <!-- ═══ MANIFIESTO ═══ -->
  <section style="
    padding:var(--section-pad);background:var(--carbon);
    border-top:1px solid var(--border);border-bottom:1px solid var(--border);
    text-align:center;position:relative;overflow:hidden;
  ">
    <div style="
      position:absolute;top:-60px;left:50%;transform:translateX(-50%);
      font-family:var(--serif);font-size:480px;color:rgba(184,150,90,.03);
      line-height:1;pointer-events:none;user-select:none;
    ">"</div>
    <div style="
      font-family:var(--sans);font-size:9px;letter-spacing:.5em;color:var(--gold);
      text-transform:uppercase;margin-bottom:52px;
      display:flex;align-items:center;justify-content:center;gap:24px;
    ">
      <span style="width:44px;height:1px;background:rgba(212,175,55,.42);display:inline-block;"></span>
      Sobre el Thriller Psicológico
      <span style="width:44px;height:1px;background:rgba(212,175,55,.42);display:inline-block;"></span>
    </div>
    <blockquote class="rv" style="
      font-family:var(--serif);font-size:clamp(22px,2.8vw,40px);font-style:italic;
      line-height:1.35;color:var(--white);max-width:880px;margin:0 auto 44px;
      position:relative;z-index:1;
    ">
      «La oscuridad no es la ausencia de luz. Es el espacio donde las personas descubren quiénes son realmente cuando nadie las observa. Eso es lo que escribo.»
    </blockquote>
    <div class="rv d1" style="font-family:var(--sans);font-size:9px;letter-spacing:.4em;color:var(--gold-dim);text-transform:uppercase;">
      — Jordi Moya Solà · L'Ametlla del Vallès, Barcelona
    </div>
  </section>

  <!-- ═══ CÍRCULO INTERIOR PREVIEW ═══ -->
  <section style="padding:var(--section-pad);background:var(--panel);border-top:1px solid var(--border);">
    <div style="max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:center;">
      <div class="rv">
        <div class="s-label">Comunidad Privada</div>
        <h2 class="s-title">El <em>Círculo</em><br>Interior</h2>
        <div class="gold-bar"></div>
        <p style="font-family:var(--sans);font-size:16px;line-height:1.9;color:var(--white-dim);margin-bottom:36px;">
          No es una newsletter. Es la cámara oscura donde trabajo: lo que no llega al libro publicado, el proceso real, los personajes que no sobrevivieron al corte editorial.
        </p>
        <a href="/circulo-interior" class="btn-primary">Unirme — acceso gratuito</a>
      </div>
      <div class="rv d2">
        <div style="
          background:var(--charcoal);border:1px solid var(--border-strong);overflow:hidden;
        ">
          <div style="padding:44px;">
            <span style="font-family:var(--sans);font-size:8.5px;letter-spacing:.5em;color:var(--gold);display:block;margin-bottom:16px;">ACCESO INMEDIATO</span>
            <div style="font-family:var(--serif);font-size:26px;font-style:italic;color:var(--white);line-height:1.3;margin-bottom:28px;">Entra en la oscuridad.</div>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:14px;">
              {[
                'Capítulo 1 completo — acceso inmediato',
                'Archivo psicológico del protagonista',
                'Fragmentos inéditos y descartados',
                'El proceso real de escritura',
                'Acceso prioritario a nuevas obras',
              ].map(item => (
                <li style="
                  font-family:var(--sans);font-size:15px;color:var(--white-dim);
                  display:flex;align-items:flex-start;gap:14px;
                  padding-bottom:14px;border-bottom:1px solid var(--white-faint);
                ">
                  <span style="color:var(--gold);font-size:7px;margin-top:5px;flex-shrink:0;">◆</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div style="padding:16px 44px;background:var(--black);font-family:var(--sans);font-size:8px;letter-spacing:.3em;color:var(--gold-dim);text-align:center;text-transform:uppercase;">
            Sin spam · Baja en cualquier momento · RGPD
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG PREVIEW ═══ -->
  <section style="padding:var(--section-pad);background:var(--black);border-top:1px solid var(--border);">
    <div style="max-width:var(--max-w);margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;">
        <div>
          <div class="s-label rv">Reflexiones</div>
          <h2 class="s-title rv">Pensar en<br>voz <em>oscura</em></h2>
        </div>
        <a href="/reflexiones" class="btn-ghost rv">Ver todas</a>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:2px;">
        {[
          {
            slug: 'por-que-el-thriller-psicologico-toca-donde-duele',
            tag: 'El Género', date: 'Febrero 2025',
            title: 'Por qué el thriller psicológico toca donde duele',
            excerpt: 'No es el miedo a lo externo. Es el reconocerse en lo que uno mismo podría llegar a hacer bajo determinadas circunstancias.',
            big: true,
