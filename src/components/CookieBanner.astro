---
/**
 * CookieBanner.astro — Banner de consentimiento RGPD
 * Persiste decisión en localStorage.
 * GA4 solo se activa tras aceptar cookies analíticas.
 */
---

<div id="cookie-banner" role="dialog" aria-label="Consentimiento de cookies" style="
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 9800;
  background: rgba(8,8,8,.97);
  border-top: 1px solid rgba(212,175,55,.3);
  backdrop-filter: blur(16px);
  padding: 28px 64px;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
">
  <!-- Texto -->
  <div style="flex: 1; min-width: 280px;">
    <p style="
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: rgba(255,255,255,.7);
      line-height: 1.7;
      margin: 0;
    ">
      Utilizamos cookies propias y de terceros para analítica (Google Analytics 4) y
      funcionamiento del sitio. Puedes aceptar todas o solo las esenciales.
      <a href="/cookies" style="color: #D4AF37; text-decoration: none; margin-left: 4px;">Política de cookies →</a>
    </p>
  </div>

  <!-- Acciones -->
  <div style="display: flex; gap: 12px; flex-shrink: 0; flex-wrap: wrap;">
    <button id="cb-reject" style="
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: rgba(255,255,255,.5);
      background: transparent;
      border: 1px solid rgba(255,255,255,.15);
      padding: 12px 24px;
      cursor: pointer;
      transition: all .3s;
      white-space: nowrap;
    ">Solo esenciales</button>

    <button id="cb-accept" style="
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      letter-spacing: .1em;
      font-weight: 700;
      text-transform: uppercase;
      color: #1a1a1a;
      background: #D4AF37;
      border: 1px solid #D4AF37;
      padding: 12px 28px;
      cursor: pointer;
      transition: all .3s;
      white-space: nowrap;
    ">Aceptar todas</button>
  </div>
</div>

<script>
  (function () {
    const COOKIE_KEY = 'jms_cookies_v1';
    const banner    = document.getElementById('cookie-banner');
    const btnAccept = document.getElementById('cb-accept');
    const btnReject = document.getElementById('cb-reject');

    // Hover states
    if (btnAccept) {
      btnAccept.addEventListener('mouseenter', () => { btnAccept.style.background = 'transparent'; btnAccept.style.color = '#D4AF37'; });
      btnAccept.addEventListener('mouseleave', () => { btnAccept.style.background = '#D4AF37'; btnAccept.style.color = '#1a1a1a'; });
    }
    if (btnReject) {
      btnReject.addEventListener('mouseenter', () => { btnReject.style.borderColor = 'rgba(255,255,255,.4)'; btnReject.style.color = '#fff'; });
      btnReject.addEventListener('mouseleave', () => { btnReject.style.borderColor = 'rgba(255,255,255,.15)'; btnReject.style.color = 'rgba(255,255,255,.5)'; });
    }

    function hideBanner() {
      if (banner) banner.style.display = 'none';
    }

    function loadGA4() {
      // Carga GA4 dinámicamente solo tras consentimiento
      const s1 = document.createElement('script');
      s1.async = true;
      s1.src = 'https://www.googletagmanager.com/gtag/js?id=G-5ESB87Y95L';
      document.head.appendChild(s1);

      const s2 = document.createElement('script');
      s2.textContent = `
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-5ESB87Y95L', { anonymize_ip: true });
      `;
      document.head.appendChild(s2);
    }

    // Recuperar decisión previa
    const decision = localStorage.getItem(COOKIE_KEY);

    if (!decision) {
      // Primera visita: mostrar banner
      if (banner) banner.style.display = 'flex';
    } else if (decision === 'accepted') {
      // Ya aceptó: cargar GA4
      loadGA4();
    }
    // Si rechazó: no hacer nada

    // Aceptar todas
    btnAccept?.addEventListener('click', () => {
      localStorage.setItem(COOKIE_KEY, 'accepted');
      hideBanner();
      loadGA4();
    });

    // Solo esenciales
    btnReject?.addEventListener('click', () => {
      localStorage.setItem(COOKIE_KEY, 'rejected');
      hideBanner();
    });
  })();
</script>
